# Kinetrix Wave 6 Test — Mecanum Drive, Kalman Filters, Edge AI
# Tests all 3 new Wave 6 libraries across all targets

program {
    # Library 23: Mecanum / Omni-directional Drive
    attach mecanum fl 2 fr 3 bl 4 br 5
    move mecanum x 50 y 0 turn 30
    wait 2000
    stop mecanum

    # Library 24: Sensor Fusion (Kalman Filter)
    attach kalman
    make float raw_val = 10.5
    make float filtered = compute kalman raw raw_val

    # Library 25: Edge AI Inference (TFLite Micro)
    load ai model "model.tflite"
    make float prediction = compute ai filtered

    println filtered
    println prediction
}
